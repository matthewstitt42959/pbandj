generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Game {
  id        String   @id @default("singleton")
  state     Json
  updatedAt DateTime @updatedAt
}

model UserGame {
  userId    String   @id
  state     Json
  updatedAt DateTime @updatedAt
}

enum UserRole {
  PLAYER
  DM
  SUPER_DM
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  username          String      @unique
  displayName       String
  password          String
  role              UserRole    @default(PLAYER)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  characters        Character[]
  campaignsCreated  Campaign[]  @relation("CampaignCreator")
  campaignsApproved Campaign[]  @relation("CampaignApprover")
  campaignsDM       Campaign[]  @relation("CampaignDM")
}

model Campaign {
  id           String         @id @default(cuid())
  name         String
  setting      String         @default("")
  openingScene String         @default("")
  hooks        Json           @default("[]")
  npcs         Json           @default("[]")
  dmNotes      String         @default("")
  status       CampaignStatus @default(DRAFT)
  rejectedNote String?
  createdById  String
  createdBy    User           @relation("CampaignCreator",  fields: [createdById],  references: [id])
  dmId         String?
  dm           User?          @relation("CampaignDM",       fields: [dmId],         references: [id])
  approvedById String?
  approvedBy   User?          @relation("CampaignApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  isActive     Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CampaignPost {
  id         String   @id @default(cuid())
  campaignId String
  author     String
  authorId   String?
  type       String   @default("player")
  content    String
  aiActions  Json?
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
}

model Rule {
  id        String   @id @default(cuid())
  title     String
  body      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WikiEntry {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("General")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Character {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  species       String
  class         String
  subclass      String?
  background    String
  backstory     String?
  level         Int       @default(1)
  abilityScores Json
  hp            Int
  maxHp         Int
  ac            Int       @default(10)
  inventory     Json      @default("[]")
  spells        Json      @default("[]")
  conditions    Json      @default("[]")
  skills        Json      @default("{}")
  campaignId    String?             // null = unassigned
  isRetired     Boolean   @default(false)
  retiredAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
